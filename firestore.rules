rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
//
// Model: a user's live location and profile is readable by anyone who
// shares a group with them, writable only by themselves. Group content
// (places, trips) is readable/writable only by that group's members.

function isSignedIn() {
  return request.auth != null;
}

function isMe(uid) {
  return isSignedIn() && request.auth.uid == uid;
}

function isGroupMember(groupId) {
  return isSignedIn() &&
    request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
}

function isGroupOwner(groupId) {
  return isSignedIn() &&
    request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid;
}

function canManagePlaces(groupId) {
  return isGroupOwner(groupId) ||
    (
      isGroupMember(groupId) &&
      get(/databases/$(database)/documents/groups/$(groupId)).data.memberPermissions[request.auth.uid].canManagePlaces == true
    );
}

function canEditPlaceDetails(groupId) {
  return isGroupOwner(groupId) ||
    (
      isGroupMember(groupId) &&
      get(/databases/$(database)/documents/groups/$(groupId)).data.memberPermissions[request.auth.uid].canEditPlaceDetails == true
    );
}

function isSelfJoinUpdate() {
  return isSignedIn() &&
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']) &&
    request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1 &&
    request.resource.data.memberUids.hasAll(resource.data.memberUids) &&
    request.auth.uid in request.resource.data.memberUids &&
    !(request.auth.uid in resource.data.memberUids);
}

function isSelfLeaveUpdate() {
  return isSignedIn() &&
    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'memberPermissions']) &&
    request.auth.uid in resource.data.memberUids &&
    !(request.auth.uid in request.resource.data.memberUids) &&
    request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1 &&
    resource.data.memberUids.hasAll(request.resource.data.memberUids) &&
    request.resource.data.memberPermissions[request.auth.uid] == null;
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Anyone signed in can read a profile (needed to render markers for
      // group members you share a group with); location fields still only
      // update at the source, and clients only ever query for uids that
      // are already members of a group they belong to.
      allow read: if isSignedIn();
      allow write: if isMe(uid);
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(groupId);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isGroupOwner(groupId) || isSelfJoinUpdate() || isSelfLeaveUpdate();
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      match /places/{placeId} {
        allow read: if isGroupMember(groupId);
        allow create, delete: if canManagePlaces(groupId);
        allow update: if canEditPlaceDetails(groupId);
      }

      match /hazards/{hazardId} {
        allow read, write: if isGroupMember(groupId);
      }

      match /trips/{tripId} {
        allow read, write: if isGroupMember(groupId);

        match /points/{pointId} {
          allow read, write: if isGroupMember(groupId);
        }
      }

      match /groupRoutes/{routeId} {
        allow read, write: if isGroupMember(groupId);
      }

      match /memberNotifications/{notificationId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) &&
          request.resource.data.fromUid == request.auth.uid;
      }
    }

    // Personal notification preferences (low-battery threshold + which
    // members to alert on). Only the owner can read/write their own.
    match /users/{uid}/groupPrefs/{groupId} {
      allow read, write: if isMe(uid);
    }
  }
}
